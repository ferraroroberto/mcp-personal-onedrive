# Copy this file to .env and fill in real values. Never commit .env.

# ---------------------------------------------------------------------------
# Microsoft Graph (required — both stdio and HTTP modes)
# ---------------------------------------------------------------------------
# Application (client) ID from your Azure App Registration.
# See README "Configuration and testing" -> Step 1.
ONEDRIVE_CLIENT_ID=

# Where to persist the MSAL token cache (binary). Default: ./.token_cache.bin
# ONEDRIVE_TOKEN_CACHE_PATH=.token_cache.bin

# ---------------------------------------------------------------------------
# OAuth gateway (required only for HTTP / claude.ai mode)
# ---------------------------------------------------------------------------
# Password you'll type into the login page when claude.ai redirects you here.
# Pick something long and unique. This is the only thing standing between
# the public internet and your OneDrive.
MCP_OAUTH_PASSWORD=

# Secret used to sign JWT bearer tokens. If unset, one is auto-generated on
# first run and written to .oauth_state.json. You can also paste a 64-char
# hex string here.
# MCP_JWT_SECRET=

# Public HTTPS base URL the MCP server is reachable at, with no trailing slash.
# Example: https://your-pc.tail1234.ts.net
# This is what you'll paste into claude.ai -> Settings -> Connectors.
MCP_PUBLIC_URL=

# Where the local HTTP server binds. Default: 127.0.0.1:8080.
# Tailscale Funnel forwards from a public *.ts.net hostname to this port.
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8080

# Where to persist OAuth state (registered clients, refresh tokens).
# MCP_OAUTH_STATE_PATH=.oauth_state.json
